# Watchtower — Docker stack configuration.
#
# Copy to ".env" (kept out of git) before running docker compose:
#     cp .env.example .env            # macOS/Linux
#     Copy-Item .env.example .env     # Windows PowerShell
#
# docker-compose.yml reads this file for variable interpolation AND injects it
# into the backend container. DATABASE_URL / REDIS_URL are constructed by
# compose from the Postgres credentials + service names (see docker-compose.yml),
# so you do NOT set them here.
#
# (For running the API directly in a local venv without Docker, use
#  backend/.env instead — its URLs point at localhost.)

# ---- PostgreSQL service / credentials -------------------------------------
POSTGRES_USER=<your username>
POSTGRES_PASSWORD=<your password>
POSTGRES_DB=<your database name>

# ---- Host port the backend is published on --------------------------------
BACKEND_PORT=8000

# ---- Application ----------------------------------------------------------
APP_ENV=production

# ---- Security / JWT  (CHANGE JWT_SECRET for anything non-local) ------------
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# ---- External price feed (CoinGecko) --------------------------------------
PRICE_CACHE_TTL_SEC=30
COINGECKO_BASE=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINGECKO_TIMEOUT_SEC=10
COINGECKO_MAX_RETRIES=3
PRICE_VS_CURRENCY=usd
TOP_TOKENS_COUNT=100

# ---- CORS -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ---- Seed credentials (scripts/seed.py) — change before any real use -------
ADMIN_EMAIL=
ADMIN_PASSWORD=
DEMO_EMAIL=
DEMO_PASSWORD=
