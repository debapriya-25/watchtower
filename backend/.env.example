APP_ENV=development

DATABASE_URL=postgresql+psycopg://username:<password>@localhost:5432/watchtower

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-me

ACCESS_TOKEN_TTL_MIN=15

REFRESH_TOKEN_TTL_DAYS=7

PRICE_CACHE_TTL_SEC=30

